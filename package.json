{
  "name": "streamdown-rn",
  "version": "0.2.1",
  "description": "High-performance streaming markdown renderer for React Native with dynamic component injection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "author": "Dark Research <engineering@darkresearch.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkresearch/generative-ui.git",
    "directory": "packages/streamdown-rn"
  },
  "keywords": [
    "react-native",
    "markdown",
    "streaming",
    "ai",
    "llm",
    "generative-ui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "test": "jest --runInBand",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "pack:verify": "node tests/package/verify-pack.mjs"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "^0.81.0"
  },
  "dependencies": {
    "prismjs": "^1.29.0",
    "react-native-syntax-highlighter": "^2.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@react-native/babel-preset": "0.81.5",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/prismjs": "^1.26.5",
    "@types/react": "19.1.17",
    "@types/react-test-renderer": "19.1.0",
    "babel-jest": "29.7.0",
    "jest": "29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.4"
  }
}
