{
  "name": "streamdown-rn",
  "version": "0.2.1",
  "description": "Streaming Markdown for React Native with native semantics, explicit security policy, and opt-in rich-content adapters",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "import": { "types": "./dist/index.d.mts", "default": "./dist/esm/index.js" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "default": "./dist/index.js"
    },
    "./ui": {
      "react-native": { "types": "./dist/components/ui/index.d.ts", "default": "./dist/components/ui/index.js" },
      "import": { "types": "./dist/components/ui/index.d.mts", "default": "./dist/esm/components/ui/index.js" },
      "require": { "types": "./dist/components/ui/index.d.ts", "default": "./dist/components/ui/index.js" },
      "default": "./dist/components/ui/index.js"
    },
    "./code": {
      "react-native": { "types": "./dist/plugins/code/index.d.ts", "default": "./dist/plugins/code/index.js" },
      "import": { "types": "./dist/plugins/code/index.d.mts", "default": "./dist/esm/plugins/code/index.js" },
      "require": { "types": "./dist/plugins/code/index.d.ts", "default": "./dist/plugins/code/index.js" },
      "default": "./dist/plugins/code/index.js"
    },
    "./cjk": {
      "react-native": { "types": "./dist/plugins/cjk/index.d.ts", "default": "./dist/plugins/cjk/index.js" },
      "import": { "types": "./dist/plugins/cjk/index.d.mts", "default": "./dist/esm/plugins/cjk/index.js" },
      "require": { "types": "./dist/plugins/cjk/index.d.ts", "default": "./dist/plugins/cjk/index.js" },
      "default": "./dist/plugins/cjk/index.js"
    },
    "./renderers": {
      "react-native": { "types": "./dist/plugins/renderers/index.d.ts", "default": "./dist/plugins/renderers/index.js" },
      "import": { "types": "./dist/plugins/renderers/index.d.mts", "default": "./dist/esm/plugins/renderers/index.js" },
      "require": { "types": "./dist/plugins/renderers/index.d.ts", "default": "./dist/plugins/renderers/index.js" },
      "default": "./dist/plugins/renderers/index.js"
    },
    "./math": {
      "react-native": { "types": "./dist/plugins/math/index.d.ts", "default": "./dist/plugins/math/index.js" },
      "import": { "types": "./dist/plugins/math/index.d.mts", "default": "./dist/esm/plugins/math/index.js" },
      "require": { "types": "./dist/plugins/math/index.d.ts", "default": "./dist/plugins/math/index.js" },
      "default": "./dist/plugins/math/index.js"
    },
    "./mermaid": {
      "react-native": { "types": "./dist/plugins/mermaid/index.d.ts", "default": "./dist/plugins/mermaid/index.js" },
      "import": { "types": "./dist/plugins/mermaid/index.d.mts", "default": "./dist/esm/plugins/mermaid/index.js" },
      "require": { "types": "./dist/plugins/mermaid/index.d.ts", "default": "./dist/plugins/mermaid/index.js" },
      "default": "./dist/plugins/mermaid/index.js"
    },
    "./mermaid/webview": {
      "react-native": { "types": "./dist/plugins/mermaid/webview/index.d.ts", "default": "./dist/plugins/mermaid/webview/index.js" },
      "import": { "types": "./dist/plugins/mermaid/webview/index.d.mts", "default": "./dist/esm/plugins/mermaid/webview/index.js" },
      "require": { "types": "./dist/plugins/mermaid/webview/index.d.ts", "default": "./dist/plugins/mermaid/webview/index.js" },
      "default": "./dist/plugins/mermaid/webview/index.js"
    }
  },
  "author": "Dark Research <engineering@darkresearch.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aqua-123/streamdown-rn.git"
  },
  "homepage": "https://github.com/Aqua-123/streamdown-rn#readme",
  "bugs": {
    "url": "https://github.com/Aqua-123/streamdown-rn/issues"
  },
  "keywords": [
    "react-native",
    "markdown",
    "streaming",
    "ai",
    "llm",
    "generative-ui"
  ],
  "scripts": {
    "build": "node scripts/build/clean.mjs && tsc -p tsconfig.json && node scripts/build/finalize-esm.mjs",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "jest --runInBand",
    "test:parity": "jest --runInBand --testMatch='<rootDir>/tests/parity/**/*.test.ts?(x)'",
    "test:device-contract": "jest --runInBand --testMatch='<rootDir>/tests/device/**/*.test.ts?(x)'",
    "test:visual": "node tests/visual/capture.mjs",
    "visual:verify": "node tests/visual/verify-integrity.mjs",
    "visual:verify:self-test": "node tests/visual/verify-integrity.mjs --self-test",
    "docs:verify:self-test": "node scripts/docs/verify.mjs --self-test",
    "docs:verify": "npm run build && node scripts/docs/verify.mjs",
    "docs:promote-release": "node scripts/docs/promote-release.mjs",
    "docs:reopen-next": "node scripts/docs/promote-release.mjs --reopen-next",
    "benchmark:parser": "bun benchmarks/parser.bench.ts",
    "benchmark:streaming": "bun benchmarks/streaming.bench.ts",
    "benchmark:host": "bun run benchmark:parser && bun run benchmark:streaming",
    "benchmark:hermes": "node scripts/benchmarks/verify-hermes.mjs",
    "benchmark:hermes:capture": "node scripts/benchmarks/capture-hermes.mjs",
    "benchmark:hermes:capture:self-test": "node scripts/benchmarks/capture-hermes.mjs --self-test",
    "benchmark:hermes:extract": "node scripts/benchmarks/extract-hermes-trace.mjs",
    "benchmark:hermes:extract:self-test": "node scripts/benchmarks/extract-hermes-trace.mjs --self-test",
    "benchmark:hermes:self-test": "node scripts/benchmarks/verify-hermes.mjs --self-test",
    "parity:refresh": "bun scripts/parity/inventory.ts --source .reference/streamdown",
    "parity:validate": "bun scripts/parity/validate.ts",
    "parity:proof": "bun scripts/parity/prove.ts",
    "parity:drift": "bun scripts/parity/check-drift.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "workflow:lint": "node scripts/ci/actionlint.mjs",
    "pack:verify": "node tests/package/verify-pack.mjs",
    "pack:verify-optional-renderers": "node tests/package/verify-optional-renderers.mjs",
    "licenses:verify": "node scripts/release/licenses.mjs",
    "advisories:verify": "bun audit",
    "release:report": "node scripts/release/report.mjs",
    "release:report:verify": "node scripts/release/verify-report.mjs",
    "release:evidence:self-test": "node scripts/release/validate-evidence-directory.selftest.mjs",
    "release:verify": "node scripts/release/verify.mjs",
    "changeset:verify": "node scripts/release/changesets.mjs",
    "changeset:version": "bunx changeset version && bun run docs:promote-release",
    "package:candidate:self-test": "node tests/package/verify-hosted-candidate.mjs --self-test",
    "package:published-fixture:verify": "node tests/package/verify-published-fixture.mjs",
    "ci:hosted": "bun run lint && bun run type-check && bun run workflow:lint && bun run parity:proof && bun run test:device-contract --silent && bun run visual:verify:self-test && bun run visual:verify && bun run parity:drift --candidate-root .reference/streamdown && bun run benchmark:streaming && bun run benchmark:hermes:capture:self-test && bun run benchmark:hermes:extract:self-test && bun run benchmark:hermes:self-test && bun run docs:verify:self-test && bun run release:evidence:self-test && bun run package:candidate:self-test && bun run package:published-fixture:verify && bun run licenses:verify && bun run advisories:verify && bun run release:report:verify && bun run changeset:verify && node tests/package/verify-hosted-candidate.mjs"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "^0.81.0 || ^0.85.0",
    "react-native-svg": ">=15.12.1 <16.0.0"
  },
  "dependencies": {
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remend": "1.3.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@react-native/babel-preset": "0.81.5",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "26.1.1",
    "@types/react": "19.1.17",
    "@types/react-test-renderer": "19.1.0",
    "@typescript-eslint/parser": "^8",
    "babel-jest": "29.7.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7",
    "jest": "29.7.0",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.15.5",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist/",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "docs/api.md",
    "docs/plugins.md",
    "docs/migration.md",
    "docs/parity.md",
    "docs/security.md",
    "docs/accessibility.md",
    "docs/performance.md",
    "docs/compatibility.md",
    "docs/visual-testing.md",
    "docs/release.md",
    "docs/third-party.md"
  ],
  "engines": {
    "node": ">=20.19.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
