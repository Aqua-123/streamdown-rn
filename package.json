{
  "name": "streamdown-rn",
  "version": "0.2.1",
  "description": "High-performance streaming markdown renderer for React Native with dynamic component injection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./code": {
      "types": "./dist/plugins/code/index.d.ts",
      "react-native": "./dist/plugins/code/index.js",
      "require": "./dist/plugins/code/index.js",
      "default": "./dist/plugins/code/index.js"
    },
    "./cjk": {
      "types": "./dist/plugins/cjk/index.d.ts",
      "react-native": "./dist/plugins/cjk/index.js",
      "require": "./dist/plugins/cjk/index.js",
      "default": "./dist/plugins/cjk/index.js"
    },
    "./renderers": {
      "types": "./dist/plugins/renderers/index.d.ts",
      "react-native": "./dist/plugins/renderers/index.js",
      "require": "./dist/plugins/renderers/index.js",
      "default": "./dist/plugins/renderers/index.js"
    },
    "./math": {
      "types": "./dist/plugins/math/index.d.ts",
      "react-native": "./dist/plugins/math/index.js",
      "require": "./dist/plugins/math/index.js",
      "default": "./dist/plugins/math/index.js"
    },
    "./mermaid": {
      "types": "./dist/plugins/mermaid/index.d.ts",
      "react-native": "./dist/plugins/mermaid/index.js",
      "require": "./dist/plugins/mermaid/index.js",
      "default": "./dist/plugins/mermaid/index.js"
    },
    "./mermaid/webview": {
      "types": "./dist/plugins/mermaid/webview/index.d.ts",
      "react-native": "./dist/plugins/mermaid/webview/index.js",
      "require": "./dist/plugins/mermaid/webview/index.js",
      "default": "./dist/plugins/mermaid/webview/index.js"
    }
  },
  "author": "Dark Research <engineering@darkresearch.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkresearch/generative-ui.git",
    "directory": "packages/streamdown-rn"
  },
  "keywords": [
    "react-native",
    "markdown",
    "streaming",
    "ai",
    "llm",
    "generative-ui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "test": "jest --runInBand",
    "test:parity": "jest --runInBand --testMatch='<rootDir>/tests/parity/**/*.test.ts?(x)'",
    "test:device-contract": "jest --runInBand --testMatch='<rootDir>/tests/device/**/*.test.ts?(x)'",
    "test:visual": "node tests/visual/capture.mjs",
    "docs:verify": "npm run build && node scripts/docs/verify.mjs",
    "benchmark:parser": "bun benchmarks/parser.bench.ts",
    "benchmark:streaming": "bun benchmarks/streaming.bench.ts",
    "benchmark:host": "bun run benchmark:parser && bun run benchmark:streaming",
    "parity:refresh": "bun scripts/parity/inventory.ts --source .reference/streamdown",
    "parity:validate": "bun scripts/parity/validate.ts",
    "parity:drift": "bun scripts/parity/check-drift.ts",
    "type-check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "pack:verify": "node tests/package/verify-pack.mjs",
    "pack:verify-optional-renderers": "node tests/package/verify-optional-renderers.mjs",
    "licenses:verify": "node scripts/release/licenses.mjs",
    "advisories:verify": "bun audit --production",
    "release:report": "node scripts/release/report.mjs",
    "release:report:verify": "node scripts/release/verify-report.mjs",
    "release:verify": "node scripts/release/verify.mjs",
    "release:publish": "bunx changeset publish",
    "changeset:verify": "node scripts/release/changesets.mjs",
    "ci:hosted": "bun run type-check && bun run test --silent && bun run test:parity --silent && bun run test:device-contract --silent && bun run parity:validate && bun run parity:drift --candidate-root .reference/streamdown && bun run build && bun run docs:verify && bun run licenses:verify && bun run advisories:verify && bun run release:report:verify && bun run changeset:verify && bun run pack:verify && bun run pack:verify-optional-renderers"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "^0.81.0 || ^0.85.0"
  },
  "dependencies": {
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remend": "1.3.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@react-native/babel-preset": "0.81.5",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "26.1.1",
    "@types/react": "19.1.17",
    "@types/react-test-renderer": "19.1.0",
    "babel-jest": "29.7.0",
    "jest": "29.7.0",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist/",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "docs/api.md",
    "docs/plugins.md",
    "docs/migration.md",
    "docs/parity.md",
    "docs/security.md",
    "docs/accessibility.md",
    "docs/performance.md",
    "docs/compatibility.md",
    "docs/visual-testing.md",
    "docs/release.md",
    "docs/third-party.md"
  ],
  "engines": {
    "node": ">=20.19.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
